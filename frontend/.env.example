# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# Google OAuth Client ID
# Get from: https://console.cloud.google.com/apis/credentials
# MUST match the backend's GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API URL
# Local development: Leave empty (uses Vite proxy)
# Production: Your backend deployment URL (Render, Railway, etc.)
# Example: https://your-backend.onrender.com
VITE_API_URL=

# ============================================
# NOTES
# ============================================
# - In local development, VITE_API_URL can be empty (Vite proxy handles it)
# - In production (Vercel/Netlify), set VITE_API_URL to your backend URL
# - All variables MUST start with VITE_ to be accessible in the frontend
# - After changing these values, restart the dev server (npm run dev)
