# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
# Local: postgresql://postgres:password@localhost:5432/blood_donation
# Production: Use your cloud provider's connection string (Render, Railway, etc.)
DATABASE_URL=postgresql://postgres:password@localhost:5432/blood_donation

# MongoDB Database URL
# Format: mongodb://host:port/database or mongodb+srv://username:password@cluster/database
# Local: mongodb://localhost:27017/bloodconnect
# Production: Use MongoDB Atlas connection string
MONGODB_URL=mongodb://localhost:27017/bloodconnect

# ============================================
# JWT CONFIGURATION
# ============================================
# Secret key for JWT token signing (MUST be changed in production!)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=dev-jwt-secret-change-in-production
# Token expiration time (e.g., 30m, 1h, 7d)
JWT_EXPIRES_IN=30m

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Your Gmail address
EMAIL_USER=your-email@gmail.com
# Gmail App Password (NOT your regular password!)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your-gmail-app-password

# ============================================
# TWILIO CONFIGURATION (Optional - for SMS)
# ============================================
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port for the backend server (default: 3001)
# In production (Render/Railway), this will be overridden by the platform
PORT=3001

# Frontend URL for CORS configuration
# Local: http://localhost:3000
# Production: Your Vercel/Netlify deployment URL
FRONTEND_URL=http://localhost:3000
